[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.2"
reloadable = true

[libraries]
macos.debug   = "res://rust/target/debug/libvoxel_terrain.dylib"
macos.release = "res://rust/target/release/libvoxel_terrain.dylib"
linux.debug.x86_64   = "res://rust/target/debug/libvoxel_terrain.so"
linux.release.x86_64 = "res://rust/target/release/libvoxel_terrain.so"
windows.debug.x86_64   = "res://rust/target/debug/voxel_terrain.dll"
windows.release.x86_64 = "res://rust/target/release/voxel_terrain.dll"
